{
  "name": "lakoora",
  "version": "0.1.0",
  "description": "Desktop UI for skillsagentsandmcp — transparent, auditable agent tooling",
  "private": true,
  "main": "./out/main/index.js",
  "scripts": {
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "start": "env -u ELECTRON_RUN_AS_NODE electron-vite preview",
    "dev": "env -u ELECTRON_RUN_AS_NODE electron-vite dev",
    "build": "electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "test:e2e": "playwright test --config e2e/playwright.config.ts",
    "test:e2e:headed": "playwright test --config e2e/playwright.config.ts --headed",
    "pack": "npm run build && electron-builder --mac dir",
    "dist:mac": "npm run build && electron-builder --mac",
    "dev:web": "vite --config vite.web.config.ts",
    "build:web": "vite build --config vite.web.config.ts",
    "preview:web": "vite preview --config vite.web.config.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@google/generative-ai": "^0.24.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@monaco-editor/react": "^4.6.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "clsx": "^2.1.1",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.9",
    "lucide-react": "^0.511.0",
    "monaco-editor": "^0.52.2",
    "node-pty": "^1.0.0",
    "openai": "^4.96.2",
    "pyright": "^1.1.410",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.4"
  },
  "devDependencies": {
    "@electron-toolkit/utils": "^4.0.0",
    "@playwright/test": "^1.61.0",
    "@types/node": "^22.13.10",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^42.1.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.1.0",
    "typescript": "^5.9.3",
    "typescript-language-server": "^5.3.0",
    "vite": "^6.2.1",
    "vitest": "^4.1.6"
  },
  "build": {
    "appId": "com.lakoora.desktop",
    "productName": "Lakoora",
    "asarUnpack": [
      "**/node_modules/node-pty/**/*"
    ],
    "publish": {
      "provider": "github",
      "owner": "lakoora",
      "repo": "lakoora"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.developer-tools",
      "identity": "Developer ID Application: <Your Name> (<TeamID>)",
      "hardenedRuntime": true,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "notarize": {
        "teamId": "<TeamID>"
      }
    }
  }
}
